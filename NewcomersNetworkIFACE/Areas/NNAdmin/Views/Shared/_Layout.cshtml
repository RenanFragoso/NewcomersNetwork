<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - @System.Web.Configuration.WebConfigurationManager.AppSettings["ApplicationName"]</title>

    @Styles.Render("~/Content/nn_admin_css")
    @Scripts.Render("~/bundles/nn_admin_init")

</head>

<body>

    <section class="menus">

        <div class="headicon">
            <img src="~/Content/Images/tpc-logo.jpg">
        </div>

        <div class="sidebaradm">
            <a class="item selected" href="@Url.Action("", "Dashboard", new { Area = "NNAdmin" })"><i class="dashboard icon"></i>Dashboard</a>
            <a class="item" href="@Url.Action("", "Classifieds", new { Area = "NNAdmin" })"><i class="list layout icon"></i>Classifieds  <div class="ui red tiny horizontal label">10</div></a>
            <a class="item" href="@Url.Action("", "Events", new { Area = "NNAdmin" })"><i class="calendar outline icon"></i>Events</a>
            <a class="item" href="@Url.Action("", "Reports", new { Area = "NNAdmin" })"><i class="line chart icon"></i>Reports</a>
            <a class="item" href="@Url.Action("", "Services", new { Area = "NNAdmin" })"><i class="browser icon"></i>Services</a>
            <a class="item" href="@Url.Action("", "Users", new { Area = "NNAdmin" })"><i class="users icon"></i>Users</a>
            <a class="item disabled" href="#"><i class="calendar icon"></i>Calendar</a>
            <a class="item disabled" href="#"><i class="mail icon"></i>Mailing</a>
        </div>

        <div class="topfixed">
            <div class="ui simple dropdown item">
                <i class="content icon"></i>
                <div class="menu">
                    <div class="item">Choice 1</div>
                    <div class="item">Choice 2</div>
                    <div class="item">Choice 3</div>
                </div>
            </div>

            <a class="item"><i class="list layout icon"></i><div class="ui floating mini circular red label">10</div></a>
            <a class="item"><i class="users icon"></i></a>
            <a class="item"><i class="browser icon"></i></a>
            <div class="left">
                <div class="ui blue label">Renan Fragoso</div>
            </div>

        </div>

    </section>

    <section class="main">
        @RenderBody()
    </section>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/semantic")
    @Scripts.Render("~/bundles/nn_admin")
    @RenderSection("scripts", required: false)

    <script type="text/javascript">
        $(document).ready(RunInit);
    </script>

     <!-- Google Charts -->
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        $('.menu .item').tab();
        $(document).ready(function () {
            google.charts.load('current', { 'packages': ['corechart'] });
            google.charts.setOnLoadCallback(drawGCharts);
        });

    </script>

</body>

</html>
